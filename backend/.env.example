# Скопируй этот файл в .env и заполни своими значениями
# В Railway эти переменные задаются в разделе Variables

# Railway создаёт автоматически когда добавляешь PostgreSQL:
DATABASE_URL=postgresql://user:password@host:port/dbname

# Сгенерируй любую длинную случайную строку (например на randomkeygen.com)
JWT_SECRET=замени-на-длинную-случайную-строку

# Твой секретный ключ для админ-панели — придумай сложный пароль
ADMIN_KEY=замени-на-свой-секретный-ключ

PORT=3000
